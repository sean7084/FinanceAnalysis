# .env
# ------------------------------------------------------------------------------
# Note: This file is ignored by git.
#
# This file is used by django-environ to set environment variables for local development.
# The variables are read in config/settings/local.py.

# GENERAL
# ------------------------------------------------------------------------------
DJANGO_SECRET_KEY=local-secret-key
DJANGO_ALLOWED_HOSTS=.localhost, .127.0.0.1, .0.0.0.0
DJANGO_DEBUG=True
DJANGO_READ_DOT_ENV_FILE=True

# DATABASE
# ------------------------------------------------------------------------------
DATABASE_URL=postgres://postgres:postgres@db:5432/finance_analysis

# CACHE
# ------------------------------------------------------------------------------
REDIS_URL=redis://redis:6379/0

# CELERY
# ------------------------------------------------------------------------------
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0
